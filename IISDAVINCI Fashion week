<html>
<head>
    <title>Home page</title>

    <style>

        body {
            background-image: url("Sfondi Neri.jpg");
            background-repeat: no-repeat;
            background-size: cover;
        }

        h1 {
            text-align: center;
            color: white;
            font-size: 56;
        }

        table {
            border-collapse: collapse;
            width: 60%;
            margin: auto;
            text-align: center;
            border: none; 
        }

        td {
            padding: 20px;
            border: none; 
        }

        img {
            width: 170px;
            height: 170px;
            object-fit: cover;
            border-radius: 80px;
        }

        a:hover img {
            transform: scale(2.2);
            transition: 0.3s;
        }

    </style>
</head>

<body>

    <h1>Brand della settimana</h1>

    <br><br>

    <table>
        <tr>
            <td><a href="Prada"><img src="prada.jpg"></a></td>
            <td><a href="Balenciaga"><img src="balenci.png"></a></td>
        </tr>

        <tr>
            <td><a href="Louis vuitton"><img src="louis.png"></a></td>
            <td><a href="Gucci"><img src="gucci.jpg"></a></td>
        </tr>

        <tr>
            <td><a href="Bottega veneta"><img src="btv.jpg"></a></td>
            <td><a href="Loro piana"><img src="loropiana.jpg"></a></td>
        </tr>
    </table>

</body>
</html>